+import React from 'react';
+
+export default function StructuredData({ data, id }: { data: Record<string, any>; id?: string }) {
+  // Security: Escape the < character to prevent XSS via malicious content or closing script tags.
+  const jsonString = JSON.stringify(data).replace(/</g, '\\u003c');
+  return (
+    <script
+      type="application/ld+json"
+      id={id}
+      dangerouslySetInnerHTML={{ __html: jsonString }}
+    />
+  );
+}
